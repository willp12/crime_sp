# Template for .streamlit/secrets.toml (never commit the real file).
# Local dev: copy to .streamlit/secrets.toml and fill in the values.
# Streamlit Cloud: set the same structure in the app's Secrets settings.
[aws]
access_key_id = "YOUR_AWS_ACCESS_KEY_ID"
secret_access_key = "YOUR_AWS_SECRET_ACCESS_KEY"
bucket = "crime-data-sp"
region = "us-east-1"
