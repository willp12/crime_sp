# Keep the pipeline image minimal: only pipeline/ is copied in, but a small
# build context also makes builds faster and prevents accidental secret bakes.
.git
.github
.streamlit
app
src
tests
queries
dags
.venv
# `**/` because in .dockerignore `*` does not cross `/` — without it only the
# context root is excluded and nested artifacts (pipeline/**/__pycache__,
# stray data files) would still enter the image via COPY.
**/__pycache__
**/*.pyc
**/*.csv
**/*.xlsx
**/*.parquet
CLAUDE.md
PLAN.md
README.md
LICENSE
